# ================================
# AgileMind Backend Configuration
# ================================

# Application Settings
ENVIRONMENT=development
APP_NAME=AgileMind
APP_VERSION=1.0.0
DEBUG=true

# Server Configuration
HOST=0.0.0.0
PORT=8000
API_PREFIX=/api/v1

# Security
SECRET_KEY=your-secret-key-here-change-in-production-min-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24 hours
REFRESH_TOKEN_EXPIRE_DAYS=30

# Password Policy
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SYMBOLS=true
DEFAULT_PASSWORD_SUFFIX=@123

# Database Configuration
DB_HOST=mysql
DB_PORT=3306
DB_NAME=agile_mind_db
DB_USER=agile_mind_user
DB_PASSWORD=your_db_password_here
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=50

# RabbitMQ Configuration
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin123
RABBITMQ_VHOST=/

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_APP_PASSWORD=your_16_character_app_password
SMTP_FROM_EMAIL=noreply@agilemind.com
SMTP_FROM_NAME=AgileMind Platform

# Email Templates
WELCOME_EMAIL_SUBJECT=Welcome to AgileMind - Your Login Details
PASSWORD_RESET_SUBJECT=AgileMind - Password Reset Request
TENANT_CREATED_SUBJECT=Welcome to AgileMind - Your Tenant Account is Ready

# Platform URLs
PLATFORM_HOME_URL=http://localhost:3000
AGILEMIND_PLATFORM_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3001

# CORS Settings
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_HEADERS=*

# Logging
LOG_LEVEL=INFO
LOG_TO_CONSOLE=true
LOG_TO_FILE=true
LOG_FORMAT=json
LOG_ROTATION=true
LOG_RETENTION_DAYS=30

# AI/ML Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

# Integration Keys
JIRA_CLIENT_ID=your_jira_client_id
JIRA_CLIENT_SECRET=your_jira_client_secret
JIRA_REDIRECT_URI=http://localhost:8000/api/v1/integrations/jira/callback

TEAMS_CLIENT_ID=your_teams_client_id
TEAMS_CLIENT_SECRET=your_teams_client_secret
TEAMS_REDIRECT_URI=http://localhost:8000/api/v1/integrations/teams/callback

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/integrations/github/callback

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Session Configuration
SESSION_TIMEOUT_MINUTES=60
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# File Upload
MAX_UPLOAD_SIZE_MB=10
ALLOWED_EXTENSIONS=.pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.jpeg,.gif

# Celery Configuration
CELERY_BROKER_URL=amqp://admin:admin123@rabbitmq:5672/
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Monitoring
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
