# ================================
# AgileMind Backend Configuration
# ================================
# COPY FROM .env.example AND CUSTOMIZE

# Application Settings
ENVIRONMENT=development
APP_NAME=AgileMind
APP_VERSION=1.0.0
DEBUG=true

# Server Configuration
HOST=0.0.0.0
PORT=8000
API_PREFIX=/api/v1

# Security
SECRET_KEY=dev-secret-key-change-this-in-production-must-be-at-least-32-chars-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# Password Policy
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SYMBOLS=true
DEFAULT_PASSWORD_SUFFIX=@123

# Database Configuration
DB_HOST=ballast.proxy.rlwy.net
DB_PORT=58607
DB_NAME=agilemind_db
DB_USER=root
DB_PASSWORD=CtBeFkVkJSUcybwQFvevXGaOMspvxDHZ
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=50

# RabbitMQ Configuration
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin123
RABBITMQ_VHOST=/

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=bweerapperuma@gmail.com
SMTP_APP_PASSWORD=nbtcbsratokxkzdu
SMTP_FROM_EMAIL=bweerapperuma@gmail.com
SMTP_FROM_NAME=AgileMind Platform

# Email Templates
WELCOME_EMAIL_SUBJECT=Welcome to AgileMind - Your Login Details
PASSWORD_RESET_SUBJECT=AgileMind - Password Reset Request
TENANT_CREATED_SUBJECT=Welcome to AgileMind - Your Tenant Account is Ready

# Platform URLs
PLATFORM_HOME_URL=http://localhost:3008
AGILEMIND_PLATFORM_URL=http://localhost:3008
FRONTEND_URL=http://localhost:3008

# CORS Settings
CORS_ORIGINS=http://localhost:3008
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_HEADERS=*

# Logging
LOG_LEVEL=DEBUG
LOG_TO_CONSOLE=true
LOG_TO_FILE=true
LOG_FORMAT=colored
LOG_ROTATION=false
LOG_RETENTION_DAYS=7

# AI/ML Configuration
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

# Integration Keys
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
JIRA_REDIRECT_URI=http://localhost:8000/api/v1/integrations/jira/callback

TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=
TEAMS_REDIRECT_URI=http://localhost:8000/api/v1/integrations/teams/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/integrations/github/callback

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Session Configuration
SESSION_TIMEOUT_MINUTES=60
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# File Upload
MAX_UPLOAD_SIZE_MB=10
ALLOWED_EXTENSIONS=.pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.jpeg,.gif

# Celery Configuration
CELERY_BROKER_URL=amqp://admin:admin123@localhost:5672/
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Monitoring
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
